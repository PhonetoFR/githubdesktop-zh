{
  "name": "github-desktop-zh",
  "version": "1.0.0-beta1",
  "description": "GitHub Desktop 汉化补丁工具 - 一键汉化，支持还原",
  "main": "src/main.ts",
  "bin": {
    "github-desktop-zh": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "ts-node src/main.ts",
    "package": "pkg dist/main.js --targets node18-win-x64 --output build/patch.exe",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": ["github-desktop", "chinese", "translation", "汉化"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "pkg": "^5.8.0",
    "typescript": "^5.3.0"
  },
  "pkg": {
    "assets": [
      "dist/**/*.js",
      "dict/**/*.json"
    ]
  }
}
